# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your API keys.
# .env is git-ignored — never commit real keys.
# ─────────────────────────────────────────────────────────────

# Required for Strategy 05 (OpenAI embedding backend)
# and Strategy 07 (proposition extraction via GPT)
OPENAI_API_KEY=sk-...

# Alternative for Strategy 05 and 07 (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────────────────────
# NOTE: Strategies 01–04, 08–10 work with NO API key.
#       Strategy 05 falls back to sentence-transformers (local)
#       Strategy 07 falls back to sentence splitting (mock)
# ─────────────────────────────────────────────────────────────
